{
  "info": {
    "_postman_id": "jsonplaceholder-api-tests-001",
    "name": "JSONPlaceholder API Tests",
    "description": "Comprehensive API test suite for JSONPlaceholder (https://jsonplaceholder.typicode.com) covering CRUD operations, status code validation, response schema checks, and chained requests.",
