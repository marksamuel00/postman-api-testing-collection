    {
      "name": "Posts - POST",
      "item": [
        {
          "name": "Create Post",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Response contains created post data', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('title', 'Automation Best Practices');",
                  "    pm.expect(jsonData).to.have.property('body');",
                  "    pm.expect(jsonData).to.have.property('userId', 1);",
                  "    pm.expect(jsonData).to.have.property('id');",
                  "});",
                  "",
                  "pm.test('Store created post ID for chained requests', function () {",
                  "    const jsonData = pm.response.json();",
                  "    pm.environment.set('created_post_id', jsonData.id);",
                  "    pm.environment.set('created_post_title', jsonData.title);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"title\": \"Automation Best Practices\",\n    \"body\": \"A comprehensive guide to building maintainable test automation frameworks.\",\n    \"userId\": 1\n}"
            },
            "url": {
              "raw": "{{base_url}}/posts",
              "host": ["{{base_url}}"],
              "path": ["posts"]
            }
          }
        },
        {
          "name": "Create Post - Validate Chained Data",
          "event": [
            {
              "listen": "pre-request",
              "script": {
                "exec": [
                  "console.log('Chained post title: ' + pm.environment.get('created_post_title'));",
                  "console.log('Chained post ID: ' + pm.environment.get('created_post_id'));"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Chained environment variable was set', function () {",
                  "    const storedTitle = pm.environment.get('created_post_title');",
                  "    pm.expect(storedTitle).to.not.be.empty;",
                  "    pm.expect(storedTitle).to.equal('Automation Best Practices');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"title\": \"CI/CD Pipeline Integration\",\n    \"body\": \"How to integrate test automation into your deployment pipeline.\",\n    \"userId\": 1\n}"
            },
            "url": {
              "raw": "{{base_url}}/posts",
              "host": ["{{base_url}}"],
              "path": ["posts"]
            }
          }
        }
